+function drawPickupCollectEffects(
+  ctx: CanvasRenderingContext2D,
+  effects: PickupCollectEffect[],
+): void {
+  for (const effect of effects) {
+    const progress = Math.min(1, effect.age / effect.duration);
+    const alpha = 1 - progress;
+    const radius = 18 + progress * 34;
+
+    ctx.save();
+    ctx.globalAlpha = alpha;
+    ctx.translate(effect.pos.x, effect.pos.y);
+    ctx.rotate(Math.PI / 4 + progress * Math.PI);
+    ctx.shadowBlur = 30;
+    ctx.shadowColor = "#facc15";
+    ctx.strokeStyle = "#fde68a";
+    ctx.lineWidth = 3;
+    ctx.beginPath();
+    ctx.rect(-radius, -radius, radius * 2, radius * 2);
+    ctx.stroke();
+    ctx.restore();
+
+    ctx.save();
+    ctx.globalAlpha = alpha;
+    ctx.fillStyle = "#fef9c3";
+    ctx.font = "900 18px Inter, ui-sans-serif, system-ui, sans-serif";
+    ctx.textAlign = "center";
+    ctx.textBaseline = "middle";
+    ctx.shadowBlur = 18;
+    ctx.shadowColor = "#facc15";
+    ctx.fillText(
+      `+${effect.value}s`,
+      effect.pos.x,
+      effect.pos.y - 28 * progress,
+    );
+    ctx.restore();
+  }
+}
+
+function drawDashEffects(
+  ctx: CanvasRenderingContext2D,
+  effects: DashEffect[],
+): void {
+  for (const effect of effects) {
+    const progress = Math.min(1, effect.age / effect.duration);
+    const alpha = 1 - progress;
+
+    ctx.save();
+    ctx.globalAlpha = alpha;
+    ctx.lineCap = "round";
+    ctx.lineWidth = 8 - progress * 4;
+    ctx.strokeStyle = "#c4b5fd";
+    ctx.shadowBlur = 24;
+    ctx.shadowColor = "#a78bfa";
+    ctx.beginPath();
+    ctx.moveTo(effect.from.x, effect.from.y);
+    ctx.lineTo(effect.to.x, effect.to.y);
+    ctx.stroke();
+    ctx.restore();
+
+    ctx.save();
+    ctx.globalAlpha = alpha * 0.78;
+    ctx.strokeStyle = "#f8fafc";
+    ctx.lineWidth = 2;
+    ctx.beginPath();
+    ctx.arc(effect.from.x, effect.from.y, effect.radius + progress * 20, 0, Math.PI * 2);
+    ctx.arc(effect.to.x, effect.to.y, effect.radius + progress * 16, 0, Math.PI * 2);
+    ctx.stroke();
+    ctx.restore();
+  }
+}
